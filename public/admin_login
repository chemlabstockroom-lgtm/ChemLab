<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Admin Login - ChemLab</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="admin_login.css">
</head>
<body>

  <div class="logo-section">
    <div class="chemlab-logo">
        <i class="fas fa-flask logo-icon"></i>
    </div>
    <h1>ChemLab Portal</h1>
    <p>Administrator Access</p>
  </div>

  <div class="login-container">
    <h2>Admin Login</h2>
    <form id="alogin">
      <label for="email">Admin Email</label>
      <input id="email" name="email" type="email" placeholder="admin@university.edu" required />

      <label for="password">Password</label>
      <div class="password-wrapper">
        <input id="password" name="password" type="password" placeholder="••••••••" required />
        <i class="fas fa-eye" id="togglePassword"></i>
      </div>

      <button type="submit">Login</button>
    </form>
    
    <div id="msg"></div>
    
    <div class="form-footer">
        <a href="index.html" class="link">Return to Home</a>
    </div>
  </div>

  <footer>
    © 2026 ChemLab Portal | Restricted Access
  </footer>

  <script>
    // Toggle Password Visibility
    const togglePassword = document.querySelector('#togglePassword');
    const password = document.querySelector('#password');

    togglePassword.addEventListener('click', function () {
      const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
      password.setAttribute('type', type);
      this.classList.toggle('fa-eye');
      this.classList.toggle('fa-eye-slash');
    });

    document.getElementById('alogin').addEventListener('submit', async e => {
      e.preventDefault();
      const payload = { 
        email: e.target.email.value.trim(), 
        password: e.target.password.value 
      };
      
      const msg = document.getElementById('msg');
      msg.style.color = "white";
      msg.innerText = "Verifying credentials...";

      try {
        const res = await fetch('/api/auth/admin/login', { 
          method: 'POST', 
          headers: {'Content-Type':'application/json'}, 
          body: JSON.stringify(payload) 
        });
        const j = await res.json();
        
        if (res.ok) {
          localStorage.setItem('adminToken', j.token);
          msg.style.color = "#ffd700";
          msg.innerText = 'Welcome ' + j.name;
          setTimeout(() => {
            window.location.href = "admin_dashboard.html";
          }, 1000);
        } else {
          msg.style.color = "#ff6b6b";
          msg.innerText = j.message || 'Access Denied';
        }
      } catch (err) {
        msg.style.color = "#ff6b6b";
        msg.innerText = "Server connection error.";
      }
    });
  </script>
</body>
</html>